  "item": [
    {
      "name": "Validar cadastro de Produtos",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Validar que o status code é 201",
              "pm.test('Status code deve ser 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// 2. Validar que a resposta contém um objeto \"data\"",
              "pm.test('Resposta deve conter um objeto \"data\"', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('data');",
              "    pm.expect(jsonData.data).to.be.an('object');",
              "});",
              "",
              "// 3. Validar que o produto foi criado com os dados corretos",
              "pm.test('Produto deve conter todos os campos obrigatórios', function () {",
              "    const jsonData = pm.response.json();",
              "    const product = jsonData.data;",
              "    ",
              "    pm.expect(product).to.have.property('id');",
              "    pm.expect(product).to.have.property('name');",
              "    pm.expect(product).to.have.property('price');",
              "    pm.expect(product).to.have.property('stock_quantity');",
              "    pm.expect(product).to.have.property('sku');",
              "    pm.expect(product).to.have.property('category_id');",
              "    pm.expect(product).to.have.property('supplier_id');",
              "});",
              "",
              "// 4. Validar que os dados enviados foram salvos corretamente",
              "pm.test('Dados do produto devem corresponder aos dados enviados', function () {",
              "    const jsonData = pm.response.json();",
              "    const product = jsonData.data;",
              "    ",
              "    pm.expect(product.name).to.equal('Mouses RGGB');",
              "    pm.expect(product.price).to.equal(299.9);",
              "    pm.expect(product.stock_quantity).to.equal(50);",
              "    pm.expect(product.sku).to.equal('MSSS-2027');",
              "    pm.expect(product.category_id).to.equal(20);",
              "    pm.expect(product.supplier_id).to.equal(10);",
              "});",
              "",
              "// 5. Validar que campos padrão têm valores corretos",
              "pm.test('Campos padrão devem ter valores corretos', function () {",
              "    const jsonData = pm.response.json();",
              "    const product = jsonData.data;",
              "    ",
              "    pm.expect(product.is_active).to.equal(true);",
              "    pm.expect(product.is_featured).to.equal(false);",
              "    pm.expect(product.discount_percentage).to.equal(0);",
              "});",
              "",
              "// 6. Validar que o slug foi gerado corretamente",
              "pm.test('Slug deve ser gerado corretamente', function () {",
              "    const jsonData = pm.response.json();",
              "    const product = jsonData.data;",
              "    ",
              "    pm.expect(product.slug).to.equal('mouses-rggb');",
              "});",
              "",
              "// 7. Validar que a resposta contém um array \"mensagens\"",
              "pm.test('Resposta deve conter um array \"mensagens\"', function () {",
              "    const jsonData = pm.response.json();",
              "    ",
              "    pm.expect(jsonData).to.have.property('mensagens');",
              "    pm.expect(jsonData.mensagens).to.be.an('array');",
              "    pm.expect(jsonData.mensagens.length).to.be.greaterThan(0);",
              "});",
              "",
              "// 8. Validar que timestamps estão presentes e são válidos",
              "pm.test('Timestamps devem estar presentes e ser válidos', function () {",
              "    const jsonData = pm.response.json();",
              "    const product = jsonData.data;",
              "    ",
              "    pm.expect(product).to.have.property('created_at');",
              "    pm.expect(product).to.have.property('updated_at');",
              "    ",
              "    // Validar que são strings de data válidas",
              "    const createdAt = new Date(product.created_at);",
              "    const updatedAt = new Date(product.updated_at);",
              "    ",
              "    pm.expect(createdAt).to.be.instanceof(Date);",
              "    pm.expect(updatedAt).to.be.instanceof(Date);",
              "    pm.expect(createdAt.getTime()).to.be.greaterThan(0);",
              "    pm.expect(updatedAt.getTime()).to.be.greaterThan(0);",
              "});",
              "",
              "// 9. Validar que campos numéricos têm os tipos corretos",
              "pm.test('Campos numéricos devem ter tipos corretos', function () {",
              "    const jsonData = pm.response.json();",
              "    const product = jsonData.data;",
              "    ",
              "    pm.expect(product.id).to.be.a('number');",
              "    pm.expect(product.price).to.be.a('number');",
              "    pm.expect(product.stock_quantity).to.be.a('number');",
              "    pm.expect(product.category_id).to.be.a('number');",
              "    pm.expect(product.supplier_id).to.be.a('number');",
              "    pm.expect(product.discount_percentage).to.be.a('number');",
              "    pm.expect(product.rating).to.be.a('number');",
              "    pm.expect(product.reviews_count).to.be.a('number');",
              "});",
              "",
              "// 10. Validar que o produto está marcado como ativo",
              "pm.test('Produto deve estar marcado como ativo', function () {",
              "    const jsonData = pm.response.json();",
              "    const product = jsonData.data;",
              "    ",
              "    pm.expect(product.is_active).to.be.true;",
              "});",
              "",
              "// 11. Validar a estrutura completa da resposta",
              "pm.test('Estrutura completa da resposta deve ser válida', function () {",
              "    const jsonData = pm.response.json();",
              "    ",
              "    // Validar estrutura raiz",
              "    pm.expect(jsonData).to.be.an('object');",
              "    pm.expect(jsonData).to.have.all.keys('data', 'mensagens');",
              "    ",
              "    // Validar estrutura do objeto data",
              "    const product = jsonData.data;",
              "    const expectedKeys = ['id', 'category_id', 'supplier_id', 'name', 'slug', 'description', ",
              "                         'short_description', 'price', 'cost_price', 'stock_quantity', ",
              "                         'reorder_level', 'image_url', 'sku', 'barcode', 'weight', ",
              "                         'is_active', 'is_featured', 'discount_percentage', 'rating', ",
              "                         'reviews_count', 'views_count', 'sales_count', 'created_at', 'updated_at'];",
              "    ",
              "    expectedKeys.forEach(key => {",
              "        pm.expect(product).to.have.property(key);",
              "    });",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
